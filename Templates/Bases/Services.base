filters:
  and:
    - categories.contains(link("Services"))
    - '!file.name.contains("Template")'
properties:
  file.name:
    displayName: Name
  note.client:
    displayName: Client
  note.deliverable-type:
    displayName: Type
  note.status:
    displayName: Status
views:
  - type: table
    name: All services
    order:
      - file.name
      - client
      - deliverable-type
      - status
    sort:
      - property: file.name
        direction: ASC
