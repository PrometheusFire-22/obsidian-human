filters:
  and:
    - categories.contains(link("Wikis"))
    - '!file.name.contains("Template")'
properties:
  file.name:
    displayName: Title
  note.wiki-status:
    displayName: Status
  note.last-compiled:
    displayName: Last Compiled
  note.sources:
    displayName: Sources
views:
  - type: table
    name: All wiki pages
    order:
      - file.name
      - wiki-status
      - last-compiled
      - sources
    sort:
      - property: note.last-compiled
        direction: DESC
