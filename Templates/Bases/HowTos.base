filters:
  and:
    - categories.contains(link("HowTos"))
    - '!file.name.contains("Template")'
properties:
  file.name:
    displayName: Name
  note.tags:
    displayName: Tags
  note.status:
    displayName: Status
views:
  - type: table
    name: All HowTos
    order:
      - file.name
      - tags
      - status
    sort:
      - property: file.name
        direction: ASC
