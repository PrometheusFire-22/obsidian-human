filters:
  and:
    - categories.contains(link("Evergreens"))
    - '!file.name.contains("Template")'
properties:
  file.name:
    displayName: Name
  note.created:
    displayName: Created
views:
  - type: table
    name: Evergreens
    order:
      - file.name
      - created
    sort:
      - column: note.created
        direction: DESC
