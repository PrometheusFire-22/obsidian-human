filters:
  and:
    - categories.contains(link("Articles"))
    - '!file.name.contains("Template")'
properties:
  file.name:
    displayName: Title
  note.author:
    displayName: Author
  note.published:
    displayName: Published
  note.rating:
    displayName: Rating
views:
  - type: table
    name: All articles
    order:
      - file.name
      - author
      - published
      - rating
    sort:
      - property: note.published
        direction: DESC
