filters:
  and:
    - categories.contains(link("Organizations"))
    - '!file.name.contains("Template")'
properties:
  file.name:
    displayName: Organization
  property.url:
    displayName: Link
  note.url:
    displayName: URL
  note.people:
    displayName: People
views:
  - type: table
    name: Organizations
    order:
      - file.name
      - url
      - people
    columnSize:
      note.url: 239
