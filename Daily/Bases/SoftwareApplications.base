filters:
  and:
    - categories.contains(link("SoftwareApplications"))
    - '!file.name.contains("Template")'
properties:
  file.name:
    displayName: Name
  note.url:
    displayName: URL
  note.rating:
    displayName: Rating
  note.stack:
    displayName: Stack
views:
  - type: table
    name: All tools
    order:
      - file.name
      - url
      - rating
      - stack
    sort:
      - property: file.name
        direction: ASC
